DATABASE_URL=

OPENAI_API_KEY=

WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_PASSWORD=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

NEXTAUTH_SECRET=
NEXTAUTH_URL=

# AES-256-GCM key used to encrypt stored secrets (WordPress app passwords,
# Instagram access tokens) at rest. Must be exactly 64 hex characters (32 bytes).
# Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=

# HMAC-SHA256 secret used to sign the publicly-reachable per-slide render
# URLs (app/api/public/carousel/[carouselId]/[slideIndex]) that the
# Instagram Graph API fetches images from. Generate one with: openssl rand -hex 32
PUBLIC_RENDER_SECRET=

# The publicly reachable base URL of this app (e.g. https://engine.example.com),
# with no trailing slash. Required for Instagram publishing: the Graph API
# fetches slide images from PUBLIC_BASE_URL + the public render route, so it
# must be reachable from Meta's servers, not just from your browser/localhost.
# Falls back to the incoming request's origin if unset.
PUBLIC_BASE_URL=

# Meta App ID (not secret) for the "Login met Instagram" OAuth button on
# the Settings page (app/api/instagram/oauth/*, lib/instagram-oauth.ts).
# From the Meta App dashboard (developers.facebook.com) -> App settings ->
# Basic. Leave empty to keep the button disabled (falls back to manual
# token entry, ?ig_error=not_configured).
META_APP_ID=

# Meta App Secret — secret, never log or commit. Same Meta App as
# META_APP_ID, used server-side only to exchange the OAuth code for tokens.
META_APP_SECRET=

# The OAuth callback URL is derived, not configured directly:
#   ${PUBLIC_BASE_URL or AUTH_URL}/api/instagram/oauth/callback
# This *exact* URL must be added under the Meta App's Facebook Login for
# Business product -> Settings -> "Valid OAuth Redirect URIs", or the
# callback will fail.
